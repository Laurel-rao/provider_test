# Database
DATABASE_URL=mysql+aiomysql://root:password@mysql:3306/api_monitor

# JWT Authentication
JWT_SECRET_KEY=your-jwt-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# Fernet Encryption Key (generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
FERNET_KEY=your-fernet-key-change-in-production

# Application
APP_NAME="API Monitor Dashboard"
DEBUG=false
DEPLOY_HOST=root@example.com
DEPLOY_REMOTE_DIR=/opt/api_monitor
DEPLOY_BRANCH=main
DEPLOY_COMPOSE_FILE=docker-compose.yml
DEPLOY_SYNC_ENV_MODE=auto
DEPLOY_DOCKER_REGISTRY_MIRROR=https://docker.1panel.live
DEPLOY_DEPLOY_MODE=restart
DEPLOY_REMOTE_UPDATE_MODE=auto
DEPLOY_GIT_REMOTE_URL=https://github.com/Laurel-rao/provider_test.git
DEPLOY_BUILD_FRONTEND=always
